{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "simple",
      "extra-files": [
        {
          "type": "json",
          "path": "custom_components/rainpoint/manifest.json",
          "jsonpath": "$.version"
        },
        {
          "type": "generic",
          "path": "custom_components/rainpoint/const.py"
        },
        {
          "type": "generic",
          "path": "sonar-project.properties"
        }
      ],
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "pull-request-header": " ",
      "pull-request-footer": " "
    }
  },
  "changelog-sections": [
    { "type": "feat", "section": "Added", "hidden": false },
    { "type": "fix", "section": "Fixed", "hidden": false },
    { "type": "perf", "section": "Performance", "hidden": false },
    { "type": "refactor", "section": "Changed", "hidden": false },
    { "type": "docs", "section": "Other Changes", "hidden": false },
    { "type": "test", "section": "Other Changes", "hidden": false },
    { "type": "ci", "section": "Other Changes", "hidden": false },
    { "type": "build", "section": "Other Changes", "hidden": false },
    { "type": "chore", "section": "Other Changes", "hidden": false }
  ]
}
